# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Environment variables — NEVER commit real secrets
.env
*.env.local

# Terraform — state files contain embedded secrets, tfvars may too
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfvars

# Vector store (generated, not source code)
faiss_index/
*.faiss
*.pkl

# MLflow / model artifacts
mlruns/
saved_models/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Docs source (keep .md, ignore .docx)
*.docx
