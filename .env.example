# ═══════════════════════════════════════════════════════
# AutoDrive Chatbot — Environment Variables
# Copy this file to .env and fill in the values you have.
# The chatbot auto-detects LOCAL vs AZURE mode.
# ═══════════════════════════════════════════════════════

# ── Option A: OpenAI API (easiest for local dev) ──────
# OPENAI_API_KEY=sk-...your-key-here...

# ── Option B: Ollama (100% free, no API key needed) ──
# Install: https://ollama.com/download  then: ollama pull llama3
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Option C: Azure OpenAI (production) ──────────────
# AZURE_OPENAI_KEY=your-azure-openai-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_KEY=your-azure-search-key
# AZURE_SEARCH_INDEX=car-dealership

# ── Backend service (for live car data) ──────────────
# CARS_API_URL=http://localhost:8000

# ── Cache (optional — uses in-memory if not set) ─────
# REDIS_URL=redis://localhost:6379

# ── General ──────────────────────────────────────────
LLM_TEMPERATURE=0.3
RETRIEVER_K=5
PORT=8002
